rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users collection
    match /users/{userId} {
      // Users can only read their own profile
      allow read: if request.auth != null 
                  && request.auth.uid == userId;
      
      // Users can create/update their own profile only
      allow create, update: if request.auth != null 
                            && request.auth.uid == userId
                            && request.auth.token.email == request.resource.data.email;
      
      // Users can delete their own profile only
      allow delete: if request.auth != null 
                    && request.auth.uid == userId;
    }
    
    // Trips collection
    match /trips/{tripId} {
      // Users can only read their own trips
      allow read: if request.auth != null 
                  && request.auth.uid == resource.data.userId;
      
      // Users can only create trips for themselves
      allow create: if request.auth != null 
                    && request.auth.uid == request.resource.data.userId;
      
      // Users can only update/delete their own trips
      allow update, delete: if request.auth != null 
                            && request.auth.uid == resource.data.userId;
    }
    
    // Countries collection - publicly readable reference data
    match /countries/{countryId} {
      allow read: if true; // Public read access for reference data
      allow write: if false; // Only admins via Firebase console
    }
    
    // Default: deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
